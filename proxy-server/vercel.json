{
    "version": 2,
    "functions": {
        "api/fetch-product.js": {
            "maxDuration": 15
        },
        "api/ai-blog-helper.js": {
            "maxDuration": 60
        },
        "api/broadcast.js": {
            "maxDuration": 30
        },
        "api/dynamic-feeds.js": {
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/api/cron/:path*",
            "destination": "/api/tasks.js?task=:path*"
        }
    ],
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Access-Control-Allow-Methods",
                    "value": "GET, POST, OPTIONS"
                },
                {
                    "key": "Access-Control-Allow-Headers",
                    "value": "Content-Type, Authorization"
                }
            ]
        }
    ],
    "crons": [
        {
            "path": "/api/ai-blog-helper.js?action=automate-full-blog",
            "schedule": "0 10 * * *"
        },
        {
            "path": "/api/ai-blog-helper.js?action=automate-trending-blog",
            "schedule": "0 22 * * *"
        },
        {
            "path": "/api/tasks.js?task=job-hunter",
            "schedule": "0 4 * * *"
        },
        {
            "path": "/api/tasks.js?task=price-sync",
            "schedule": "0 4 * * *"
        },
        {
            "path": "/api/tasks.js?task=auto-index",
            "schedule": "30 20 * * *"
        }
    ]
}