            }
          ]
        }
      },
      "id": "7fa84d9f-028c-4861-848e-2e0617300abc",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [200, 300]
    },
    {
