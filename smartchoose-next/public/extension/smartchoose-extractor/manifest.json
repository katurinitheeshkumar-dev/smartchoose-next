{
  "manifest_version": 3,
  "name": "SmartChoose Extractor Pro",
  "version": "2.0",
  "description": "One-click product extractor for SmartChoose Admin. Works on Amazon.in & Flipkart.com.",
  "permissions": ["activeTab", "scripting", "storage", "clipboardWrite", "clipboardRead"],
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "*://*.amazon.in/*",
    "*://*.amazon.com/*",
    "*://*.flipkart.com/*",
    "*://smartchoose.in/*",
    "*://www.smartchoose.in/*",
    "*://localhost/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["scraper.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
