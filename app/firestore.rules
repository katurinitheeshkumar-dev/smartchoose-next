rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is an admin
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper function to get admin role
    function getRole() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role;
    }

    match /products/{product} {
      allow read: if true;
      allow write: if isAdmin() && (getRole() == 'super_admin' || getRole() == 'editor');
    }
    
    match /reels/{reel} {
      allow read: if true;
      allow write: if isAdmin() && (getRole() == 'super_admin' || getRole() == 'editor');
    }

    match /reelPublications/{pub} {
      allow read: if true;
      allow write: if isAdmin() && (getRole() == 'super_admin' || getRole() == 'editor');
    }

    match /blogPosts/{post} {
      allow read: if true;
      allow write: if isAdmin() && (getRole() == 'super_admin' || getRole() == 'editor');
    }

    match /jobs/{job} {
      allow read: if true;
      allow write: if isAdmin() && (getRole() == 'super_admin' || getRole() == 'editor');
    }

    match /settings/{setting} {
      allow read: if true;
      allow write: if isAdmin() && getRole() == 'super_admin';
    }

    // Admin Only Collections
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && getRole() == 'super_admin';
    }

    match /analytics/{analytic} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /automationLogs/{log} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /commentAutomations/{automation} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    match /system/{doc} {
      allow read, write: if isAdmin() && getRole() == 'super_admin';
    }
  }
}
