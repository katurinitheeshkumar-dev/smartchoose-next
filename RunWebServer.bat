@echo off
echo Starting local web server for Smartchoose...
powershell -NoProfile -ExecutionPolicy Bypass -Command "$port = 8080; $path = Join-Path $PWD 'app\dist'; if (-not (Test-Path $path)) { Write-Host 'Error: app\dist folder not found. Please build the project first.' -ForegroundColor Red; pause; exit }; $listener = New-Object System.Net.HttpListener; $listener.Prefixes.Add('http://localhost:' + $port + '/'); $listener.Start(); Write-Host 'Started Server!'; Start-Process ('http://localhost:' + $port + '/'); while ($listener.IsListening) { $context = $listener.GetContext(); $request = $context.Request; $response = $context.Response; $reqPath = $request.Url.LocalPath; if ($reqPath -eq '/') { $reqPath = '/index.html' }; $filePath = Join-Path $path $reqPath; if (Test-Path $filePath -PathType Leaf) { if ($filePath.EndsWith('.js')) { $response.ContentType = 'application/javascript' } elseif ($filePath.EndsWith('.css')) { $response.ContentType = 'text/css' } elseif ($filePath.EndsWith('.html')) { $response.ContentType = 'text/html' }; $buffer = [System.IO.File]::ReadAllBytes($filePath); $response.ContentLength64 = $buffer.Length; $output = $response.OutputStream; $output.Write($buffer, 0, $buffer.Length); $output.Close() } else { $response.StatusCode = 404; $response.Close() } }"
pause
